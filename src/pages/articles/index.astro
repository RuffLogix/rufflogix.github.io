---
import FormalLayout from "../../layouts/FormalLayout.astro";

const MEDIUM_URL = "https://api.rss2json.com/v1/api.json?rss_url=https://medium.com/feed/@rufflogix";

interface MediumPost {
  title: string;
  pubDate: string;
  guid: string;
  author: string;
  description: string;
}

function excerpt(html: string, max = 180) {
  const t = html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
  return t.length > max ? t.slice(0, max) + '…' : t;
}

function fmtDate(s: string) {
  return new Date(s).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

let posts: MediumPost[] = [];
try {
  const r = await fetch(MEDIUM_URL);
  if (r.ok) {
    const d = await r.json();
    posts = d.items || [];
  }
} catch { /* silent */ }
---

<FormalLayout title="Writing — RuffLogix">
  <div class="articles-page page-wrap">

    <header class="articles-header">
      <p class="label-strong reveal" style="margin-bottom: 1rem;">Writing</p>
      <h1 class="articles-title reveal d1">Articles &amp; Notes</h1>
      <p class="articles-sub reveal d2">
        Technical writing published on
        <a href="https://medium.com/@rufflogix" target="_blank" rel="noopener noreferrer"
           class="medium-link">Medium @rufflogix</a>
      </p>
    </header>

    {posts.length > 0 ? (
      <div class="posts-list">
        {posts.map((post, i) => (
          <a href={post.guid} target="_blank" rel="noopener noreferrer"
             class:list={['post-row reveal', `d${(i % 4) + 1}`]}>
            <div class="post-row-inner">
              <div class="post-meta-row">
                <span class="label post-date">{fmtDate(post.pubDate)}</span>
              </div>
              <h2 class="post-title">{post.title}</h2>
              <p class="post-excerpt">{excerpt(post.description)}</p>
            </div>
            <div class="post-arrow-wrap">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2"
                   stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state reveal">
        <p class="label">No posts available — check back soon.</p>
        <a href="https://medium.com/@rufflogix" target="_blank" rel="noopener noreferrer"
           class="btn btn-ghost" style="margin-top: 1.5rem;">
          Visit Medium
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</FormalLayout>

<style>
.articles-page {
  padding-top: 5rem;
  padding-bottom: 6rem;
}

.articles-header { margin-bottom: 4rem; }
.articles-title {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--text-1);
  margin-bottom: 0.75rem;
}
.articles-sub {
  font-size: 1rem;
  color: var(--text-2);
  line-height: 1.65;
}
.medium-link {
  color: var(--accent);
  transition: opacity var(--t-fast);
}
.medium-link:hover { opacity: 0.7; }

.posts-list { display: flex; flex-direction: column; }

.post-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1.5rem;
  padding: 1.75rem 0;
  border-bottom: 1px solid var(--border);
  transition: all var(--t-fast);
  cursor: pointer;
}
.post-row:first-child { border-top: 1px solid var(--border); }
.post-row:hover .post-title { color: var(--text-1); }
.post-row:hover .post-arrow-wrap { opacity: 1; transform: translateX(0); }

.post-row-inner { flex: 1; }
.post-meta-row { margin-bottom: 0.5rem; }
.post-date { color: var(--text-3); }

.post-title {
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--text-1);
  line-height: 1.45;
  margin-bottom: 0.5rem;
  letter-spacing: -0.01em;
  transition: color var(--t-fast);
}
.post-excerpt {
  font-size: 0.85rem;
  color: var(--text-2);
  line-height: 1.7;
}

.post-arrow-wrap {
  flex-shrink: 0;
  color: var(--text-3);
  opacity: 0.4;
  transform: translateX(-4px);
  transition: all var(--t-mid) var(--expo);
  margin-top: 0.2rem;
}

.empty-state {
  padding: 4rem 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

@media (max-width: 640px) {
  .post-row { padding: 1.35rem 0; }
}
</style>
