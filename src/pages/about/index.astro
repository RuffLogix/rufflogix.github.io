---
import FormalLayout from "../../layouts/FormalLayout.astro";
import {
  educationalInformation,
  experienceInformation,
  personalInfo,
} from "../../constants/timeline.constant";
import { techStackData } from "../../constants/techstack.constant";
---

<FormalLayout title="About — RuffLogix">
  <div class="about-page page-wrap">

    <!-- Page header -->
    <header class="about-header">
      <div class="about-header-grid">
        <!-- Left: text -->
        <div class="about-header-text">
          <p class="label-strong reveal" style="margin-bottom: 1.25rem;">Background</p>
          <h1 class="about-title reveal d1">
            Software engineer,<br />
            <span class="about-title-dim">AI researcher.</span>
          </h1>
          <p class="about-intro reveal d2">
            Building at the intersection of systems programming, machine intelligence,
            and experimental interfaces. Based in Bangkok, Thailand.
          </p>

          <!-- Quick stats row -->
          <div class="about-stats reveal d3">
            <div class="stat-item">
              <span class="stat-number">8+</span>
              <span class="stat-label label">Internships</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">3+</span>
              <span class="stat-label label">Years building</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">6</span>
              <span class="stat-label label">Major awards</span>
            </div>
          </div>
        </div>

        <!-- Right: portrait -->
        <div class="about-photo-wrap reveal d2">
          <div class="about-photo-frame">
            <img
              src="/images/latest-profile.jpeg"
              alt="RuffLogix — Teejuta Sriwaranon"
              class="about-photo"
              width="533"
              height="800"
              loading="eager"
            />
            <!-- Subtle bottom fade so photo blends into page -->
            <div class="about-photo-fade" aria-hidden="true"></div>
          </div>
          <!-- Floating caption badge -->
          <div class="about-photo-badge">
            <span class="badge-dot"></span>
            <span class="badge-text label">Full Stack Engineer @ Agoda</span>
          </div>
        </div>
      </div>
    </header>

    <!-- ── EXPERIENCE ──────────────────────────────────────────── -->
    <section class="section">
      <p class="label-strong section-label reveal">Experience</p>

      <div class="timeline">
        {experienceInformation.map((exp, i) => (
          <div class:list={['tl-item reveal', `d${(i % 4) + 1}`]}>
            <div class="tl-left">
              <span class="tl-duration label">{exp.duration}</span>
            </div>
            <div class="tl-right">
              <div class="tl-org">
                <img src={exp.image} alt={exp.instituteName}
                     class="tl-logo" width="28" height="28" loading="lazy" />
                <div>
                  <h3 class="tl-name">
                    {exp.link ? (
                      <a href={exp.link} target="_blank" rel="noopener noreferrer" class="tl-link">
                        {exp.instituteName}
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                          <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                        </svg>
                      </a>
                    ) : exp.instituteName}
                  </h3>
                  <p class="tl-role">{exp.program}</p>
                </div>
              </div>
              <p class="tl-desc">{exp.description}</p>
              <span class="tl-location label">{exp.location}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── EDUCATION ───────────────────────────────────────────── -->
    <section class="section">
      <p class="label-strong section-label reveal">Education</p>

      <div class="timeline">
        {educationalInformation.map((edu, i) => (
          <div class:list={['tl-item reveal', `d${(i % 4) + 1}`]}>
            <div class="tl-left">
              <span class="tl-duration label">{edu.duration}</span>
            </div>
            <div class="tl-right">
              <div class="tl-org">
                <img src={edu.image} alt={edu.instituteName}
                     class="tl-logo" width="28" height="28" loading="lazy" />
                <div>
                  <h3 class="tl-name">{edu.instituteName}</h3>
                  <p class="tl-role">{edu.program}</p>
                </div>
              </div>
              <p class="tl-desc">{edu.description}</p>
              <span class="tl-location label">{edu.location}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── SKILLS ──────────────────────────────────────────────── -->
    <section class="section">
      <p class="label-strong section-label reveal">Technical Skills</p>

      <div class="skills-grid">
        {techStackData.map((cat, i) => (
          <div class:list={['skill-block reveal', `d${(i % 4) + 1}`]}>
            <h3 class="skill-cat" style="font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 500; color: var(--text-1); margin-bottom: 0.9rem;">
              {cat.category}
            </h3>
            <div class="skill-tags">
              {cat.technologies.map(t => <span class="tag">{t.name}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── CONTACT ─────────────────────────────────────────────── -->
    <section class="section contact-section">
      <p class="label-strong section-label reveal">Contact</p>
      <div class="contact-block reveal d1">
        <p class="contact-line">
          Open to collaborations, research projects, and interesting problems.
        </p>
        <div class="contact-links">
          <a href={`mailto:${personalInfo.email}`} class="contact-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            {personalInfo.email}
          </a>
          <a href={personalInfo.github} target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/teejuta-sriwaranon/" target="_blank"
             rel="noopener noreferrer" class="contact-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a href={personalInfo.kaggle} target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.825 23.859c-.022.092-.117.141-.281.141h-3.139c-.187 0-.351-.082-.492-.248l-5.178-6.589-1.448 1.374v5.111c0 .235-.117.352-.351.352H5.505c-.236 0-.354-.117-.354-.352V.353c0-.233.118-.353.354-.353h2.431c.234 0 .351.12.351.353v14.343l6.203-6.272c.165-.165.33-.246.495-.246h3.239c.144 0 .236.06.285.18.046.149.034.255-.036.315l-6.555 6.344 6.836 8.507c.095.104.117.208.07.336"/>
            </svg>
            Kaggle
          </a>
          <a href={personalInfo.codeforces} target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M4.5 7.5C5.328 7.5 6 8.172 6 9v10.5c0 .828-.672 1.5-1.5 1.5h-3C.672 21 0 20.328 0 19.5V9c0-.828.672-1.5 1.5-1.5h3zm9-4.5c.828 0 1.5.672 1.5 1.5v15c0 .828-.672 1.5-1.5 1.5h-3c-.828 0-1.5-.672-1.5-1.5v-15c0-.828.672-1.5 1.5-1.5h3zm9 7.5c.828 0 1.5.672 1.5 1.5v7.5c0 .828-.672 1.5-1.5 1.5h-3c-.828 0-1.5-.672-1.5-1.5V12c0-.828.672-1.5 1.5-1.5h3z"/>
            </svg>
            Codeforces
          </a>
        </div>
      </div>
    </section>

  </div>
</FormalLayout>

<style>
.about-page {
  padding-top: 5rem;
  padding-bottom: 6rem;
}

/* ── HEADER ───────────────────────────────────────────────── */
.about-header { margin-bottom: 5rem; }

.about-header-grid {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 4rem;
  align-items: start;
}

.about-header-text {
  display: flex;
  flex-direction: column;
  padding-top: 0.5rem;
}

.about-title {
  font-size: clamp(2.2rem, 5.5vw, 4rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.08;
  color: var(--text-1);
  margin-bottom: 1.25rem;
}
.about-title-dim { color: var(--text-2); font-weight: 500; }

.about-intro {
  font-size: 1rem;
  color: var(--text-2);
  max-width: 52ch;
  line-height: 1.75;
  margin-bottom: 2.5rem;
}

/* Stats row */
.about-stats {
  display: flex;
  gap: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}
.stat-item {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.stat-number {
  font-size: 1.75rem;
  font-weight: 700;
  letter-spacing: -0.04em;
  color: var(--text-1);
  line-height: 1;
}
.stat-label { color: var(--text-3); }

/* Photo */
.about-photo-wrap {
  position: relative;
  align-self: start;
}
.about-photo-frame {
  position: relative;
  border-radius: var(--r-xl);
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--bg-3);
  /* subtle inner shadow for depth */
  box-shadow: 0 0 0 1px var(--border) inset;
}
.about-photo {
  width: 100%;
  height: auto;
  display: block;
  /* slight desaturation in dark mode for tonal cohesion */
  filter: saturate(0.88) contrast(1.02);
  transition: filter var(--t-slow);
}
[data-theme="light"] .about-photo {
  filter: saturate(1) contrast(1);
}
/* Bottom gradient fade blends photo into bg */
.about-photo-fade {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 35%;
  background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
  pointer-events: none;
}
[data-theme="light"] .about-photo-fade {
  background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
}

/* Floating badge */
.about-photo-badge {
  position: absolute;
  bottom: -0.75rem;
  left: 1.25rem;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.45rem 0.85rem;
  background: color-mix(in srgb, var(--bg-2) 90%, transparent);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border-hover);
  border-radius: 999px;
  white-space: nowrap;
}
.badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 6px rgba(74, 222, 128, 0.6);
  flex-shrink: 0;
  animation: pulse-dot 2.4s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; box-shadow: 0 0 6px rgba(74, 222, 128, 0.6); }
  50%       { opacity: 0.7; box-shadow: 0 0 12px rgba(74, 222, 128, 0.8); }
}
.badge-text {
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  color: var(--text-1);
  text-transform: none;
}

/* Sections */
.section {
  padding: 4rem 0;
  border-top: 1px solid var(--border);
}
.section-label { margin-bottom: 2.5rem; }

/* Timeline */
.timeline { display: flex; flex-direction: column; gap: 0; }

.tl-item {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 2rem;
  padding: 1.75rem 0;
  border-bottom: 1px solid var(--border);
}
.tl-item:last-child { border-bottom: none; }

.tl-left { padding-top: 0.15rem; }
.tl-duration {
  color: var(--text-2);
  font-size: 0.68rem;
  line-height: 1.5;
}

.tl-org {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  margin-bottom: 0.8rem;
}
.tl-logo {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  object-fit: contain;
  background: var(--bg-3);
  padding: 2px;
  flex-shrink: 0;
  margin-top: 2px;
  border: 1px solid var(--border);
}
.tl-name {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: 0.2rem;
  letter-spacing: -0.01em;
}
.tl-link {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  color: var(--text-1);
  transition: color var(--t-fast);
}
.tl-link:hover { color: var(--accent); }
.tl-role {
  font-size: 0.82rem;
  color: var(--text-2);
  font-weight: 500;
}
.tl-desc {
  font-size: 0.875rem;
  color: var(--text-2);
  line-height: 1.75;
  margin-bottom: 0.75rem;
}
.tl-location { color: var(--text-3); font-size: 0.68rem; }

/* Skills */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.skill-block { }
.skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

/* Contact */
.contact-section { }
.contact-block { }
.contact-line {
  font-size: 0.95rem;
  color: var(--text-2);
  margin-bottom: 1.5rem;
  max-width: 52ch;
  line-height: 1.7;
}
.contact-links { display: flex; flex-wrap: wrap; gap: 1.5rem; }
.contact-link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-1);
  padding: 0.6rem 1.1rem;
  border: 1px solid var(--border-hover);
  border-radius: var(--r-md);
  transition: all var(--t-mid) var(--expo);
  background: var(--surface);
}
.contact-link:hover {
  background: var(--surface-hover);
  border-color: var(--text-3);
  transform: translateY(-1px);
}

/* Responsive */
@media (max-width: 960px) {
  .about-header-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .about-photo-wrap {
    order: -1;
    max-width: 300px;
    margin: 0 auto;
  }
}

@media (max-width: 860px) {
  .skills-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
  .tl-item  { grid-template-columns: 110px 1fr; gap: 1.25rem; }
}

@media (max-width: 640px) {
  .about-page    { padding-top: 3rem; padding-bottom: 4rem; }
  .about-header  { margin-bottom: 3rem; }
  .section       { padding: 2.5rem 0; }

  .tl-item       { grid-template-columns: 1fr; gap: 0.35rem; }
  .tl-left       { padding-top: 0; }
  .tl-duration   { display: block; margin-bottom: 0.5rem; }

  .skills-grid   { grid-template-columns: 1fr; }
  .about-title   { font-size: clamp(1.8rem, 9vw, 2.8rem); }
  .about-intro   { font-size: 0.92rem; }
  .about-stats   { gap: 1.25rem; flex-wrap: wrap; }
  .stat-number   { font-size: 1.35rem; }
  .about-photo-wrap { max-width: 240px; margin: 0 auto; }
  .contact-links { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
  .contact-link  { width: 100%; justify-content: flex-start; }
}
</style>
