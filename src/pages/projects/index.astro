---
import FormalLayout from "../../layouts/FormalLayout.astro";
import { projectInformation } from "../../constants/project.constant";

const primaryLink = (p: (typeof projectInformation)[number]) =>
  p.githubLinks?.[0]?.url ?? p.infoLink ?? p.articleLink ?? null;
---

<FormalLayout title="Work — RuffLogix">
  <div class="projects-page page-wrap">
    <!-- Page header -->
    <header class="projects-header">
      <p class="label-strong reveal" style="margin-bottom: 1rem;">
        Selected Work
      </p>
      <h1 class="projects-title reveal d1">Projects &amp; Experiments</h1>
      <p class="projects-sub reveal d2">
        Systems built for performance, AI, and exploration.
      </p>
      <p class="projects-count label reveal d3">
        {String(projectInformation.length).padStart(2, "0")} entries
      </p>
    </header>

    <!-- Project index -->
    <ol class="proj-index">
      {
        projectInformation.map((p, i) => {
          const href = primaryLink(p);
          return (
            <li class:list={["proj-row reveal", `d${(i % 4) + 1}`]}>
              <a
                class="proj-main"
                href={href ?? undefined}
                target={href ? "_blank" : undefined}
                rel={href ? "noopener noreferrer" : undefined}
              >
                <div class="proj-head">
                  <span class="proj-num">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="proj-meta">
                    <span class="label proj-cat">{p.category}</span>
                    <span class="proj-sep" aria-hidden="true">
                      /
                    </span>
                    <span class="label proj-dim">{p.date}</span>
                    <span class="proj-sep" aria-hidden="true">
                      /
                    </span>
                    <span class="label proj-dim">{p.role}</span>
                  </span>
                  <span class="proj-arrow" aria-hidden="true">
                    <svg
                      width="17"
                      height="17"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="7" y1="17" x2="17" y2="7" />
                      <polyline points="7 7 17 7 17 17" />
                    </svg>
                  </span>
                </div>

                <h2 class="proj-title">{p.title}</h2>
                <p class="proj-desc">{p.description}</p>
              </a>

              <div class="proj-foot">
                <div class="proj-tags">
                  {p.tags.map((t) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>

                {(p.githubLinks?.length || p.articleLink || p.infoLink) && (
                  <div class="proj-links">
                    {p.githubLinks?.map((link) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="proj-link"
                      >
                        <svg
                          width="12"
                          height="12"
                          viewBox="0 0 24 24"
                          fill="currentColor"
                        >
                          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                        </svg>
                        {link.label}
                      </a>
                    ))}
                    {p.articleLink && (
                      <a
                        href={p.articleLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="proj-link"
                      >
                        <svg
                          width="12"
                          height="12"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          <polyline points="15 3 21 3 21 9" />
                          <line x1="10" y1="14" x2="21" y2="3" />
                        </svg>
                        Article
                      </a>
                    )}
                    {p.infoLink && (
                      <a
                        href={p.infoLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="proj-link"
                      >
                        <svg
                          width="12"
                          height="12"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          <polyline points="15 3 21 3 21 9" />
                          <line x1="10" y1="14" x2="21" y2="3" />
                        </svg>
                        Live
                      </a>
                    )}
                  </div>
                )}
              </div>
            </li>
          );
        })
      }
    </ol>

    <!-- Empty state -->
    {
      projectInformation.length === 0 && (
        <div class="empty-state">
          <p class="label">More projects coming soon</p>
        </div>
      )
    }
  </div>
</FormalLayout>

<style>
  .projects-page {
    padding-top: 5rem;
    padding-bottom: 6rem;
  }

  /* Header */
  .projects-header {
    margin-bottom: 2.5rem;
  }
  .projects-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-1);
    margin-bottom: 0.75rem;
  }
  .projects-sub {
    font-size: 1rem;
    color: var(--text-2);
    max-width: 48ch;
    line-height: 1.65;
  }
  .projects-count {
    margin-top: 1.1rem;
    color: var(--text-3);
  }

  /* ── Index list — single flush-left edge ─────────────────── */
  .proj-index {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--border);
  }

  .proj-row {
    position: relative;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  /* Accent marker — sits in the left gutter, only on hover */
  .proj-row::before {
    content: "";
    position: absolute;
    left: -1rem;
    top: 1.5rem;
    bottom: 1.5rem;
    width: 2px;
    background: var(--accent);
    border-radius: 2px;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--t-mid) var(--expo);
  }
  .proj-row:hover::before {
    transform: scaleY(1);
  }

  /* Clickable region */
  .proj-main {
    display: block;
  }

  .proj-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }
  .proj-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-3);
    transition: color var(--t-fast);
  }
  .proj-row:hover .proj-num {
    color: var(--accent);
  }
  .proj-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    min-width: 0;
  }
  .proj-cat {
    color: var(--accent);
    font-weight: 500;
  }
  .proj-dim {
    color: var(--text-3);
  }
  .proj-sep {
    color: var(--border-hover);
    font-size: 0.72rem;
  }
  .proj-arrow {
    margin-left: auto;
    color: var(--text-3);
    opacity: 0.5;
    transition: all var(--t-mid) var(--expo);
  }
  .proj-row:hover .proj-arrow {
    color: var(--text-1);
    opacity: 1;
    transform: translate(2px, -2px);
  }

  .proj-title {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-1);
    line-height: 1.3;
    margin-bottom: 0.4rem;
    transition: color var(--t-fast);
  }
  .proj-row:hover .proj-title {
    color: var(--accent);
  }
  .proj-desc {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.6;
    max-width: 64ch;
  }

  /* Foot — tags top row, links below */
  .proj-foot {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 1rem;
  }
  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .proj-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem;
  }
  .proj-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.74rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    color: var(--text-3);
    transition: color var(--t-fast);
  }
  .proj-link:hover {
    color: var(--text-1);
  }

  /* Empty */
  .empty-state {
    padding: 4rem 0;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .projects-page {
      padding-top: 3rem;
      padding-bottom: 4rem;
    }
    .projects-header {
      margin-bottom: 1.75rem;
    }
    .proj-row::before {
      left: -0.7rem;
    }
    .proj-title {
      font-size: 1.12rem;
    }
    .proj-arrow {
      display: none;
    }
    .proj-foot {
      gap: 0.5rem;
    }
  }
</style>
