---
// Get current page path for active state
const currentPath = Astro.url.pathname;

// Navigation items
const navItems = [
    { href: "/", label: "Home" },
    { href: "/about", label: "About" },
    { href: "/articles", label: "Articles" },
    { href: "/projects", label: "Projects" },
];
---

<!-- Desktop navbar (pill, bottom center) -->
<nav
    class="navbar-container fixed bottom-8 left-1/2 transform -translate-x-1/2 z-50 hidden md:flex py-3 px-8 gap-8 items-center justify-center backdrop-blur-sm rounded-full"
    role="navigation"
    aria-label="Main navigation"
>
    {
        navItems.map((item) => {
            const isActive =
                currentPath === item.href ||
                (item.href !== "/" && currentPath.startsWith(item.href));

            return (
                <a
                    href={item.href}
                    class={`navbar-link ${isActive ? "navbar-link-active" : ""}`}
                    aria-current={isActive ? "page" : undefined}
                >
                    {item.label}
                </a>
            );
        })
    }
</nav>

<!-- Mobile navbar (hamburger, bottom right) -->
<div class="mobile-nav fixed bottom-8 right-6 z-50 flex flex-col items-end gap-3 md:hidden">
    <!-- Menu items (shown when open) -->
    <div id="mobile-menu" class="mobile-menu flex flex-col items-end gap-2" aria-hidden="true">
        {
            navItems.map((item) => {
                const isActive =
                    currentPath === item.href ||
                    (item.href !== "/" && currentPath.startsWith(item.href));

                return (
                    <a
                        href={item.href}
                        class={`mobile-nav-link ${isActive ? "mobile-nav-link-active" : ""}`}
                        aria-current={isActive ? "page" : undefined}
                    >
                        {item.label}
                    </a>
                );
            })
        }
    </div>

    <!-- Hamburger button -->
    <button
        id="hamburger-btn"
        class="hamburger-btn"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
    >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
    </button>
</div>

<script>
    const btn = document.getElementById("hamburger-btn");
    const menu = document.getElementById("mobile-menu");

    btn?.addEventListener("click", () => {
        const isOpen = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!isOpen));
        menu?.setAttribute("aria-hidden", String(isOpen));
        btn.classList.toggle("is-open", !isOpen);
        menu?.classList.toggle("is-open", !isOpen);
    });

    // Close menu when a link is clicked
    menu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
            btn?.setAttribute("aria-expanded", "false");
            menu.setAttribute("aria-hidden", "true");
            btn?.classList.remove("is-open");
            menu.classList.remove("is-open");
        });
    });
</script>

<style>
    /* ── Desktop pill navbar ── */
    .navbar-container {
        border: 1px solid var(--color-border);
        background-color: var(--color-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: var(--shadow-lg);
        transition: all var(--timing-medium) var(--easing-default);
    }

    .navbar-container:hover {
        box-shadow: var(--shadow-hover);
    }

    .navbar-link {
        color: var(--color-text);
        text-decoration: none;
        font-weight: var(--font-weight-medium);
        padding: 0.5rem 1rem;
        border-radius: var(--border-radius);
        position: relative;
        transition: all var(--timing-fast) var(--easing-default);
        outline: none;
    }

    .navbar-link:hover {
        color: var(--color-accent);
        background-color: rgba(16, 185, 129, 0.1);
        transform: translateY(-1px);
    }

    .navbar-link:focus-visible {
        color: var(--color-accent);
        background-color: rgba(16, 185, 129, 0.1);
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
    }

    .navbar-link-active {
        color: var(--color-accent);
        background-color: rgba(16, 185, 129, 0.15);
        font-weight: var(--font-weight-semibold);
    }

    .navbar-link-active:hover {
        background-color: rgba(16, 185, 129, 0.2);
        transform: translateY(-1px);
    }

    .navbar-container {
        animation: navbar-slide-up var(--timing-medium) var(--easing-bounce);
    }

    @keyframes navbar-slide-up {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    /* ── Mobile hamburger button ── */
    .hamburger-btn {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--color-border);
        background-color: var(--color-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: var(--shadow-lg);
        cursor: pointer;
        transition: all var(--timing-fast) var(--easing-default);
        outline: none;
    }

    .hamburger-btn:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
    }

    .hamburger-line {
        display: block;
        width: 20px;
        height: 2px;
        background-color: var(--color-text);
        border-radius: 2px;
        transition: all var(--timing-fast) var(--easing-default);
        transform-origin: center;
    }

    /* Animate to X when open */
    .hamburger-btn.is-open .hamburger-line:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }
    .hamburger-btn.is-open .hamburger-line:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }
    .hamburger-btn.is-open .hamburger-line:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* ── Mobile menu items ── */
    .mobile-menu {
        opacity: 0;
        pointer-events: none;
        transform: translateY(8px);
        transition:
            opacity var(--timing-fast) var(--easing-default),
            transform var(--timing-fast) var(--easing-default);
    }

    .mobile-menu.is-open {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
    }

    .mobile-nav-link {
        display: block;
        color: var(--color-text);
        text-decoration: none;
        font-weight: var(--font-weight-medium);
        font-size: 0.95rem;
        padding: 0.5rem 1.25rem;
        border-radius: 999px;
        border: 1px solid var(--color-border);
        background-color: var(--color-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: var(--shadow-lg);
        transition: all var(--timing-fast) var(--easing-default);
        white-space: nowrap;
        outline: none;
    }

    .mobile-nav-link:hover {
        color: var(--color-accent);
        background-color: rgba(16, 185, 129, 0.1);
    }

    .mobile-nav-link:focus-visible {
        color: var(--color-accent);
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
    }

    .mobile-nav-link-active {
        color: var(--color-accent);
        background-color: rgba(16, 185, 129, 0.15);
        font-weight: var(--font-weight-semibold);
    }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
        .navbar-container,
        .navbar-link,
        .hamburger-btn,
        .hamburger-line,
        .mobile-menu,
        .mobile-nav-link {
            transition: none;
            animation: none;
        }
    }

    /* ── High contrast ── */
    @media (prefers-contrast: high) {
        .navbar-container,
        .hamburger-btn,
        .mobile-nav-link {
            border-width: 2px;
            background-color: var(--color-background);
        }
    }
</style>
